# Тема «Гжель» для D2-диаграмм HumanTurn
# Маппинг D2 theme tokens → палитра сайта (src/styles/gzhel.css)
# Сайт только светлый — dark-theme-overrides не нужны.
#
# Цветовые роли:
#   B1-B6  — основной кобальт-синий (заливки фигур)
#   AA2-AA5 — графитовый сланец (линии соединений, контрастные на белом)
#   AB4-AB5 — приглушённый бирюзовый (вторичные элементы, комплемент к кобальту)
#   N1-N7   — нейтральная шкала (текст → фон)

vars: {
  d2-config: {
    theme-overrides: {
      # ── Основной кобальт (заливки) ──
      B1: "#16306f"   # тёмный кобальт (= --sl-color-accent-high)
      B2: "#1c2a52"   # (= gray-1)
      B3: "#2f54b0"   # основной кобальт (= --sl-color-accent)
      B4: "#8593b5"   # приглушённый сине-серый (= gray-4)
      B5: "#d3e1f9"   # светлый акцент (= --sl-color-accent-low)
      B6: "#e8effc"   # очень светлый — фон контейнеров

      # ── Графитовый сланец (соединения) ──
      AA2: "#2c3a64"  # тёмный — основные линии (= gray-2)
      AA4: "#50608a"  # средний — вторичные линии (= gray-3)
      AA5: "#bcc8e0"  # светлый — третичные (= gray-5)

      # ── Приглушённый акцент (вторичные фигуры) ──
      AB4: "#50608a"  # сланец (= gray-3)
      AB5: "#e6edf8"  # светлый сланец (= gray-6)

      # ── Нейтральная шкала (текст → фон) ──
      N1: "#0e1a3a"   # текст на светлом фоне (= --sl-color-white light)
      N2: "#1c2a52"   # = gray-1
      N3: "#2c3a64"   # = gray-2
      N4: "#50608a"   # = gray-3
      N5: "#8593b5"   # = gray-4
      N6: "#e6edf8"   # = gray-6
      N7: "#ffffff"   # фон диаграммы (= --sl-color-black light)
    }
  }
}
